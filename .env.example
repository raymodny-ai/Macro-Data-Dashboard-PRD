# =============================================================================
# 宏观流动性与资产定价状态识别系统 - 环境变量配置
# =============================================================================
# 复制本文件为 .env 并填写实际值：
#   cp .env.example .env

# -----------------------------------------------------------------------------
# TimescaleDB (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=macro_dashboard
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=change_me_strong_password

# TimescaleDB connection string (used by FastAPI, Airflow)
DATABASE_URL=postgresql+asyncpg://dashboard:change_me_strong_password@timescaledb:5432/macro_dashboard
DATABASE_URL_SYNC=postgresql://dashboard:change_me_strong_password@timescaledb:5432/macro_dashboard

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# -----------------------------------------------------------------------------
# Airflow
# -----------------------------------------------------------------------------
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql://dashboard:change_me_strong_password@timescaledb:5432/macro_dashboard
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=change_me_airflow_secret
AIRFLOW__WEBSERVER__WEB_SERVER_PORT=8080

# Airflow DAG 配置
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__CATCHUP_BY_DEFAULT=false

# -----------------------------------------------------------------------------
# Celery (SEC EDGAR 专用独立队列)
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -----------------------------------------------------------------------------
# FastAPI
# -----------------------------------------------------------------------------
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_ENV=development
FASTAPI_DEBUG=true

# -----------------------------------------------------------------------------
# 外部 API Keys
# -----------------------------------------------------------------------------
# FRED (Federal Reserve Economic Data) - https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Alpha Vantage (备用数据源) - https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# SEC EDGAR 合规请求头 - https://www.sec.gov/os/webmaster-faq#developers
SEC_COMPANY_NAME=MacroDashboard
SEC_CONTACT_EMAIL=admin@local
SEC_USER_AGENT=MacroDashboard admin@local

# -----------------------------------------------------------------------------
# 系统阈值配置 (B4 升级为数据库热更新)
# -----------------------------------------------------------------------------
# 流动性走廊: SOFR-IORB 利差三级状态触发器
THRESHOLD_SPREAD_TIGHT=-0.03
THRESHOLD_SPREAD_STRESS=0.0
THRESHOLD_CRISIS_BURST_BPS=0.10

# 财政增量: 熊陡判定
THRESHOLD_BID_TO_COVER=2.4
THRESHOLD_ACM_PREMIUM=0.01

# 数据质量
SPREAD_MIN=-2.0
SPREAD_MAX=2.0
MAX_CONSECUTIVE_NULLS=3

# -----------------------------------------------------------------------------
# 备份策略
# -----------------------------------------------------------------------------
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=7

# -----------------------------------------------------------------------------
# Webhook (DAG 完成事件 → 缓存驱逐)
# -----------------------------------------------------------------------------
WEBHOOK_SECRET=change_me_webhook_secret
WEBHOOK_URL=http://fastapi:8000/api/v1/internal/cache-invalidate

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_SSE_URL=http://localhost:8000/api/v1/events/stream
